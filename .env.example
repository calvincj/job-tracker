# Copy this file to .env and fill in whichever of these you're using.
# .env is gitignored - it never gets committed.

# Adzuna broad net (free key: https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJobs federal listings (free key: https://developer.usajobs.gov/apirequest/)
USAJOBS_KEY=
USAJOBS_EMAIL=

# Email delivery (Gmail app password: https://myaccount.google.com/apppasswords)
GMAIL_USER=
GMAIL_APP_PASSWORD=
DIGEST_TO_EMAIL=
